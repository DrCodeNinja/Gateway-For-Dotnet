{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "{{JWT_SIGNING_KEY}}",
    "Issuer": "{{JWT_ISSUER}}",
    "Audience": "{{JWT_AUDIENCE}}",
    "DefaultExpiresInHours": 1,
    "DefaultUsername": "{{DEFAULT_USERNAME}}"
  }
}
